<!DOCTYPE html>
<html>
<head>
<title>CareLink Edge</title>
<style>
body {
    font-family: Arial, sans-serif;
    background: #f3f4f6;
    margin: 0;
    color: #111827;
}

.header {
    background: #111827;
    color: white;
    padding: 22px;
}

.container {
    padding: 20px;
}

.card {
    background: white;
    padding: 22px;
    margin-bottom: 22px;
    border-radius: 14px;
}

.grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
}

.form-group {
    margin-bottom: 14px;
}

label {
    display: block;
    margin-bottom: 6px;
    font-weight: 700;
}

input,
select,
textarea,
button {
    width: 100%;
    box-sizing: border-box;
    padding: 11px 12px;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    font-size: 15px;
}

textarea {
    min-height: 90px;
    resize: vertical;
}

button {
    background: #2563eb;
    color: white;
    border: none;
    margin-top: 6px;
    cursor: pointer;
    font-weight: 700;
}

button:hover {
    opacity: 0.95;
}

.delete {
    background: #ef4444;
    width: auto;
    padding: 8px 14px;
}

.badge {
    padding: 5px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    display: inline-block;
}

.normal { background: #bbf7d0; }
.warning { background: #fde68a; }
.critical { background: #fecaca; }
.emergency { background: #ddd6fe; }

table {
    width: 100%;
    border-collapse: collapse;
}

td, th {
    padding: 12px 10px;
    border-bottom: 1px solid #ddd;
    text-align: left;
    vertical-align: top;
}

.panel-sub {
    color: #6b7280;
    margin-top: -4px;
    margin-bottom: 18px;
}

.stats-line {
    font-size: 18px;
    font-weight: 600;
}

.empty-row {
    color: #6b7280;
}

@media (max-width: 980px) {
    .grid {
        grid-template-columns: 1fr;
    }
}
</style>
</head>

<body>

<div class="header">
    <h1>CareLink Edge Dashboard</h1>
</div>

<div class="container">

    <div class="card">
        <h2>System Stats</h2>
        <div class="stats-line">
            Residents: {{ stats.residents }} |
            Events: {{ stats.events }} |
            Critical Alerts: {{ stats.critical }}
        </div>
    </div>

    <div class="grid">

        <div class="card">
            <h2>Add Resident</h2>
            <p class="panel-sub">Fill in the resident profile information below.</p>

            <form method="POST" action="/add_resident">
                <div class="form-group">
                    <label>Full Name</label>
                    <input name="full_name" placeholder="Full Name" required>
                </div>

                <div class="form-group">
                    <label>Blood Group</label>
                    <input name="blood_group" placeholder="Blood Group" required>
                </div>

                <div class="form-group">
                    <label>Date of Birth</label>
                    <input name="date_of_birth" placeholder="DOB" required>
                </div>

                <div class="form-group">
                    <label>Diet</label>
                    <input name="diet" placeholder="Diet" required>
                </div>

                <div class="form-group">
                    <label>Allergies</label>
                    <input type="text" name="allergies" placeholder="Penicillin, peanuts, etc." required>
                </div>

                <div class="form-group">
                    <label>Disability</label>
                    <input type="text" name="disability" placeholder="Mobility, hearing, vision, etc." required>
                </div>

                <div class="form-group">
                    <label>Notes</label>
                    <textarea name="notes" placeholder="Notes" required></textarea>
                </div>

                <button type="submit">Add Resident</button>
            </form>
        </div>

        <div class="card">
            <h2>Log Event</h2>
            <p class="panel-sub">Create a resident-linked care event entry.</p>

            <form method="POST" action="/log_event">
                <div class="form-group">
                    <label>Select Resident</label>
                    <select name="resident_id" required>
                        <option value="">Choose resident</option>
                        {% for r in residents %}
                        <option value="{{ r.id }}">{{ r.full_name }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group">
                    <label>Event Type</label>
                    <select name="event_type" required>
                        <option value="">Choose event</option>
                        <option value="Medication">Medication</option>
                        <option value="Pulse">Pulse</option>
                        <option value="Emergency">Emergency</option>
                        <option value="Check">Check</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Status</label>
                    <select name="status" required>
                        <option value="">Choose status</option>
                        <option value="normal">normal</option>
                        <option value="warning">warning</option>
                        <option value="critical">critical</option>
                        <option value="emergency">emergency</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Event Notes</label>
                    <textarea name="notes" placeholder="Notes" required></textarea>
                </div>

                <button type="submit">Log Event</button>
            </form>
        </div>

    </div>

    <div class="card">
        <h2>Residents</h2>

        <table>
            <tr>
                <th>Name</th>
                <th>Blood</th>
                <th>DOB</th>
                <th>Diet</th>
                <th>Allergies</th>
                <th>Disability</th>
                <th>Notes</th>
                <th></th>
            </tr>

            {% for resident in residents %}
            <tr>
                <td>{{ resident["full_name"] }}</td>
                <td>{{ resident["blood_group"] or "—" }}</td>
                <td>{{ resident["date_of_birth"] or "—" }}</td>
                <td>{{ resident["diet"] or "—" }}</td>
                <td>{{ resident["allergies"] or "—" }}</td>
                <td>{{ resident["disability"] or "—" }}</td>
                <td>{{ resident["notes"] or "—" }}</td>
                <td>
                    <form method="POST" action="/delete_resident/{{ resident['id'] }}">
                        <button class="delete">Delete</button>
                    </form>
                </td>
            </tr>
            {% endfor %}

            {% if not residents %}
            <tr>
                <td colspan="8" class="empty-row">No residents yet.</td>
            </tr>
            {% endif %}
        </table>
    </div>

    <div class="card">
        <h2>Recent Events</h2>

        <table>
            <tr>
                <th>Name</th>
                <th>Blood</th>
                <th>DOB</th>
                <th>Diet</th>
                <th>Allergies</th>
                <th>Disability</th>
                <th>Event</th>
                <th>Status</th>
                <th>Time</th>
                <th></th>
            </tr>

            {% for e in events %}
            <tr>
                <td>{{ e["resident_name"] }}</td>
                <td>{{ e["resident_blood_group"] or "—" }}</td>
                <td>{{ e["resident_dob"] or "—" }}</td>
                <td>{{ e["resident_diet"] or "—" }}</td>
                <td>{{ e["resident_allergies"] or "—" }}</td>
                <td>{{ e["resident_disability"] or "—" }}</td>
                <td>{{ e["event_type"] }}</td>
                <td><span class="badge {{ e['status'] }}">{{ e["status"] }}</span></td>
                <td>{{ e["created_at"] }}</td>
                <td>
                    <form method="POST" action="/delete/{{ e['id'] }}">
                        <button class="delete">Delete</button>
                    </form>
                </td>
            </tr>
            {% endfor %}

            {% if not events %}
            <tr>
                <td colspan="10" class="empty-row">No events yet.</td>
            </tr>
            {% endif %}
        </table>
    </div>

</div>

</body>
</html>
EOF
