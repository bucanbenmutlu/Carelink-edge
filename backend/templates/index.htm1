<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CareLink Edge Dashboard</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 30px;
            background: #f7f7f7;
        }
        h1 {
            margin-bottom: 10px;
        }
        form, table {
            background: white;
            padding: 16px;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            margin-bottom: 20px;
        }
        input, select, button {
            padding: 8px;
            margin: 6px 0;
            width: 100%;
            max-width: 420px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            text-align: left;
            border-bottom: 1px solid #ddd;
            padding: 10px;
        }
        .delete-btn {
            width: auto;
            max-width: none;
            padding: 6px 12px;
            cursor: pointer;
            background-color: #ff4d4d;
            color: white;
            border: none;
            border-radius: 5px;
        }
        .delete-btn:hover {
            background-color: #cc0000;
        }
    </style>
</head>
<body>

    <h1>CareLink Edge Dashboard</h1>
    <p>Manual MVP event logger for caregiver monitoring.</p>

    <form method="POST" action="/log">
        <label>Resident Name</label><br>
        <input type="text" name="resident_name" placeholder="Resident A" required><br>

        <label>Event Type</label><br>
        <select name="event_type">
            <option value="medication">Medication</option>
            <option value="mood">Mood</option>
            <option value="emergency_button">Emergency Button</option>
            <option value="pulse_alert">Pulse Alert</option>
        </select><br>

        <label>Status</label><br>
        <select name="status">
            <option value="normal">Normal</option>
            <option value="warning">Warning</option>
            <option value="critical">Critical</option>
            <option value="emergency">Emergency</option>
        </select><br>

        <label>Notes</label><br>
        <input type="text" name="notes" placeholder="Optional notes"><br>

        <button type="submit">Log Event</button>
    </form>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Resident</th>
                <th>Event</th>
                <th>Status</th>
                <th>Notes</th>
                <th>Created At</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for event in events %}
            <tr>
                <td>{{ event["id"] }}</td>
                <td>{{ event["resident_name"] }}</td>
                <td>{{ event["event_type"] }}</td>
                <td>{{ event["status"] }}</td>
                <td>{{ event["notes"] }}</td>
                <td>{{ event["created_at"] }}</td>
                <td>
                    <form method="POST" action="/delete/{{ event['id'] }}">
                        <button type="submit" class="delete-btn">Delete</button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

</body>
</html>
