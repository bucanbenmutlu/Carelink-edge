<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CareLink Edge</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f4f6f8;
            color: #1f2937;
        }

        .page {
            max-width: 1350px;
            margin: 0 auto;
            padding: 24px;
        }

        .hero {
            background: linear-gradient(135deg, #0f172a, #1d4ed8);
            color: white;
            border-radius: 18px;
            padding: 28px;
            margin-bottom: 24px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        }

        .hero h1 {
            margin: 0 0 10px;
            font-size: 40px;
        }

        .hero p {
            margin: 0;
            font-size: 17px;
            color: #dbeafe;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(2, minmax(220px, 1fr));
            gap: 16px;
            margin: 20px 0 28px;
        }

        .card {
            background: white;
            border-radius: 16px;
            padding: 18px;
            box-shadow: 0 3px 12px rgba(0,0,0,0.07);
        }

        .card .label {
            color: #6b7280;
            font-size: 14px;
            margin-bottom: 8px;
        }

        .card .value {
            font-size: 30px;
            font-weight: 700;
        }

        .section-title {
            margin: 10px 0 14px;
            font-size: 24px;
        }

        .panel-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 28px;
        }

        .panel {
            background: white;
            border-radius: 16px;
            padding: 22px;
            box-shadow: 0 3px 12px rgba(0,0,0,0.07);
        }

        .panel h2 {
            margin-top: 0;
            margin-bottom: 6px;
            font-size: 22px;
        }

        .panel-sub {
            margin-top: 0;
            color: #6b7280;
            margin-bottom: 18px;
        }

        label {
            display: block;
            margin: 12px 0 6px;
            font-weight: 600;
        }

        input, select, textarea, button {
            width: 100%;
            box-sizing: border-box;
            padding: 11px 12px;
            border-radius: 10px;
            border: 1px solid #d1d5db;
            font-size: 15px;
        }

        textarea {
            min-height: 90px;
            resize: vertical;
        }

        button {
            margin-top: 16px;
            border: none;
            background: #2563eb;
            color: white;
            font-weight: 700;
            cursor: pointer;
        }

        button:hover {
            opacity: 0.95;
        }

        .table-wrap {
            background: white;
            border-radius: 16px;
            box-shadow: 0 3px 12px rgba(0,0,0,0.07);
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: #eef2f7;
            padding: 14px;
            text-align: left;
            font-size: 14px;
        }

        td {
            padding: 14px;
            border-top: 1px solid #edf0f2;
            vertical-align: top;
        }

        .status-badge {
            display: inline-block;
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 700;
        }

        .normal {
            background: #dcfce7;
            color: #166534;
        }

        .warning {
            background: #fef3c7;
            color: #92400e;
        }

        .critical {
            background: #fee2e2;
            color: #991b1b;
        }

        .emergency {
            background: #f3e8ff;
            color: #6b21a8;
        }

        .delete-btn {
            width: auto;
            padding: 8px 14px;
            background: #ef4444;
            border-radius: 8px;
        }

        .delete-btn:hover {
            background: #dc2626;
        }

        .muted {
            color: #6b7280;
        }

        @media (max-width: 980px) {
            .panel-grid {
                grid-template-columns: 1fr;
            }

            .cards {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
<div class="page">

    <div class="hero">
        <h1>CareLink Edge</h1>
        <p>Welcome to the care operations dashboard. Resident records and care event logging are managed from this page.</p>
    </div>

    <div class="cards">
        <div class="card">
            <div class="label">Total Residents</div>
            <div class="value">{{ counts["resident_count"] }}</div>
        </div>
        <div class="card">
            <div class="label">Total Logged Events</div>
            <div class="value">{{ counts["event_count"] }}</div>
        </div>
    </div>

    <div class="panel-grid">
        <div class="panel">
            <h2>Resident Profile Panel</h2>
            <p class="panel-sub">Add a resident with core profile data.</p>

            <form method="POST" action="/add_resident">
                <label>Full Name</label>
                <input type="text" name="full_name" placeholder="Resident full name" required>

                <label>Blood Group</label>
                <input type="text" name="blood_group" placeholder="A+, O-, AB+, etc.">

                <label>Date of Birth</label>
                <input type="date" name="date_of_birth">

                <label>Diet</label>
                <input type="text" name="diet" placeholder="Low salt, diabetic, soft food, etc.">

                <label>Notes</label>
                <textarea name="notes" placeholder="Resident profile notes"></textarea>

                <button type="submit">Add Resident</button>
            </form>
        </div>

        <div class="panel">
            <h2>Care Logging Panel</h2>
            <p class="panel-sub">This is panel 1 on the welcome page. More panels can be added later.</p>

            <form method="POST" action="/log">
                <label>Select Resident</label>
                <select name="resident_id" required>
                    <option value="">Choose a resident</option>
                    {% for resident in residents %}
                    <option value="{{ resident['id'] }}">
                        {{ resident['full_name'] }}{% if resident['blood_group'] %} — {{ resident['blood_group'] }}{% endif %}
                    </option>
                    {% endfor %}
                </select>

                <label>Event Type</label>
                <select name="event_type" required>
                    <option value="">Choose event</option>
                    <option value="medication">Medication</option>
                    <option value="mood_check">Mood Check</option>
                    <option value="diet_note">Diet Note</option>
                    <option value="blood_pressure_check">Blood Pressure Check</option>
                    <option value="pulse_alert">Pulse Alert</option>
                    <option value="emergency_button">Emergency Button</option>
                    <option value="care_note">General Care Note</option>
                </select>

                <label>Status</label>
                <select name="status" required>
                    <option value="normal">Normal</option>
                    <option value="warning">Warning</option>
                    <option value="critical">Critical</option>
                    <option value="emergency">Emergency</option>
                </select>

                <label>Event Notes</label>
                <textarea name="notes" placeholder="Add notes for this log entry"></textarea>

                <button type="submit">Log Event</button>
            </form>
        </div>
    </div>

    <h2 class="section-title">Recent Logs</h2>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Resident</th>
                    <th>Blood Type</th>
                    <th>Date of Birth</th>
                    <th>Diet</th>
                    <th>Event</th>
                    <th>Status</th>
                    <th>Notes</th>
                    <th>Time of Log</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for e in events %}
                <tr>
                    <td>{{ e["id"] }}</td>
                    <td>{{ e["resident_name"] }}</td>
                    <td>{{ e["resident_blood_group"] or "—" }}</td>
                    <td>{{ e["resident_dob"] or "—" }}</td>
                    <td>{{ e["resident_diet"] or "—" }}</td>
                    <td>{{ e["event_type"] }}</td>
                    <td>
                        <span class="status-badge {{ e['status']|lower }}">
                            {{ e["status"] }}
                        </span>
                    </td>
                    <td>{{ e["event_notes"] or "—" }}</td>
                    <td>{{ e["created_at"] }}</td>
                    <td>
                        <form method="POST" action="/delete/{{ e['id'] }}">
                            <button type="submit" class="delete-btn">Delete</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
                {% if not events %}
                <tr>
                    <td colspan="10" class="muted">No logs yet.</td>
                </tr>
                {% endif %}
            </tbody>
        </table>
    </div>

</div>
</body>
</html>
